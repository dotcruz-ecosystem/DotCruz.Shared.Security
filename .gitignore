## Ignore Visual Studio temporary files, build results, and user settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
msvs/

# Visual Studio 2015/2017 cache directory
.vs/
# Uncomment if you have tasks that create toplevel folders there
#top-level/

# Project lake effects
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
ASPNETCORE_ENVIRONMENT

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/
# template packages
*.template.config

# JetBrains Rider
.idea/
*.sln.iml

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Visual Studio Code
.vscode/

# Local .env files
.env
.env.local
.env.*.local
